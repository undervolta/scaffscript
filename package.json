{
  "name": "vortex-gml",
  "version": "0.1.0",
  "description": "A superset language of GML with TypeScript-like module system",
  "module": "src/index.ts",
  "main": "dist/index.js",
  "bin": {
    "vortex": "dist/index.js"
  },
