 * Line: @line. File: "@file". Counter: @counter.
 *
 * @param x The first parameter.
 * @param y The second parameter.
 * @returns The sum of x and y.
 */
//@content method
var my_func = @valueof test_function

//@content URL

@content test_function

//@content test_function2

/// won't removed
show_debug_message($"y = @:y, z = @valueof z, STRING = {@nameof STRING}");
//include * from "./const"
include { "alias",  } from "./class"

var inst = new MyClass("John", 20);
inst.print();

